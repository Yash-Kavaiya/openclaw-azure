# OpenClaw Environment Configuration
# Copy this file to .env and fill in the values

# Application
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-change-in-production
PORT=8000
WORKERS=4

# Database (Azure PostgreSQL Flexible Server)
DATABASE_URL=postgresql+asyncpg://openclaw:password@your-server.postgres.database.azure.com:5432/openclaw

# Redis (Azure Cache for Redis)
REDIS_URL=rediss://:your-redis-key@your-redis.redis.cache.windows.net:6380/0

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=openclaw

# Azure Key Vault
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:3000
ALLOWED_HOSTS=your-domain.com,localhost

# Azure Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;...
